# Copiez ce fichier en .env et renseignez vos propres valeurs.
# Ne jamais committer de vrais secrets dans .env.example.

# --- Base de données ---
MONGO_URI=mongodb://localhost:27017/
DB_NAME=hopital_db

# --- Sécurité applicative ---
FLASK_SECRET_KEY=
JWT_SECRET=
JWT_EXPIRY_MINUTES=60
TOTP_INTERVAL_SECONDS=300
SESSION_COOKIE_SECURE=true
FLASK_DEBUG=false
PORT=5000

# --- Email (OTP) : compte SMTP Gmail utilisé pour l'envoi des codes OTP ---
# Utiliser un "mot de passe d'application" Gmail, pas le mot de passe du compte.
EMAIL_SENDER=
EMAIL_APP_PASSWORD=

# --- Kafka (optionnel : si absent, le pipeline bascule automatiquement sur le
#     mode CSV via streaming/simulate_from_csv.py) ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=access_logs
ALERT_SCORE_THRESHOLD=6
